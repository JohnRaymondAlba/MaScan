# Environment Configuration Template
# Copy this file as .env and fill in your values

# Database URL (Supabase PostgreSQL connection string)
# Format: postgresql://user:password@host:5432/database
# Leave empty to use SQLite (local development)
DATABASE_URL=

# Flask Secret Key (keep this secret!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-here-min-32-chars

# Flask Environment
# Options: development, production
FLASK_ENV=development

# Redis URL (for session storage on Vercel)
# Format: redis://:password@host:port
# Sign up at upstash.com or redis.com for free tier
REDIS_URL=

# Debug Mode
# Options: True, False
DEBUG=True

# Host and Port (local development)
HOST=127.0.0.1
PORT=5000
